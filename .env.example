APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=primary

# Primary connection (Author, author_tag, labelables — on connection "primary")
DB_PRIMARY_DRIVER=mysql
DB_PRIMARY_HOST=127.0.0.1
DB_PRIMARY_PORT=3306
DB_PRIMARY_DATABASE=laravel_primary
DB_PRIMARY_USERNAME=sail
DB_PRIMARY_PASSWORD=password
DB_PRIMARY_CHARSET=utf8mb4
DB_PRIMARY_COLLATION=utf8mb4_unicode_ci
# DB_PRIMARY_SCHEMA=laravel_primary
# DB_PRIMARY_PREFIX=

# Secondary connection (Article, Comment, Profile, Tag, Label, Sticker — on connection "secondary")
# IMPORTANT: both Laravel connections must target the same server so cross-connection JOINs can execute.
# - pgsql: both connections share one physical database and are separated by schema
#   (DB_SECONDARY_DATABASE=laravel_primary, DB_SECONDARY_SCHEMA=laravel_secondary).
# - sqlite: each connection uses its own file; cross-file access is enabled at runtime via
#   ATTACH DATABASE, with DB_*_SCHEMA acting as the attached schema name.
DB_SECONDARY_DRIVER=mysql
DB_SECONDARY_HOST=127.0.0.1
DB_SECONDARY_PORT=3306
DB_SECONDARY_DATABASE=laravel_secondary
DB_SECONDARY_USERNAME=sail
DB_SECONDARY_PASSWORD=password
DB_SECONDARY_CHARSET=utf8mb4
DB_SECONDARY_COLLATION=utf8mb4_unicode_ci
# DB_SECONDARY_SCHEMA=laravel_secondary
# DB_SECONDARY_PREFIX=

# Use ./switch-db.sh {mysql|pgsql|sqlite} to toggle driver-specific values above.

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
